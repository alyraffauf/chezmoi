{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "proxy": "",
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "git_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "bottom_dock_layout": "left_aligned",
  "tabs": {
    "git_status": true
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "button_layout": "platform_default"
  },
  "search": {
    "case_sensitive": true
  },
  "semantic_tokens": "combined",
  "which_key": {
    "enabled": true
  },
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "session": {
    "trust_all_worktrees": true
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle"
  },
  "show_edit_predictions": true,
  "theme": "One Dark Pro",
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    },
    "model_parameters": []
  },
  "auto_indent_on_paste": true,
  "auto_install_extensions": {
    "one-dark-pro": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "minimap": {
    "show": "auto"
  },
  "preferred_line_length": 80,
  "soft_wrap": "preferred_line_length",
  "use_on_type_format": true,
  "wrap_guides": [80],
  "lsp": {
    "gopls": {
      "initialization_options": {
        "directoryFilters": ["-vendor"]
      }
    }
  }
}
