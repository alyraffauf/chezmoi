{
  "git": {
    "inline_blame": {
      "show_commit_summary": false
    }
  },
  "outline_panel": {
    "default_width": 240.0
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false
  },
  "debugger": {
    "button": false
  },
  "diagnostics": {
    "button": false
  },
  "prettier": {
    "allowed": true
  },
  "default_open_behavior": "new_window",
  "buffer_line_height": "standard",
  "collaboration_panel": {
    "button": false
  },
  "icon_theme": "Zed (Default)",
  "allow_rewrap": "anywhere",
  "edit_predictions": {
    "mode": "subtle"
  },
  "use_smartcase_search": true,
  "cli_default_open_behavior": "new_window",
  "ssh_connections": [
    {
      "host": "jubilife",
      "args": [],
      "projects": [
        {
          "paths": ["/home/aly/src/cute.haus"],
        },
        {
          "paths": ["/home/aly/src/nixcfg"],
        },
        {
          "paths": ["/home/aly/src/nynx"],
        },
      ],
    },
  ],
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "auto",
      },
      "type": "registry",
    },
    "opencode": {
      "default_config_options": {
        "mode": "build",
        "effort": "max",
        "model": "opencode-go/deepseek-v4-pro",
      },
      "favorite_config_option_values": {
        "model": ["opencode-go/deepseek-v4-pro"],
      },
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "model": "default",
      },
      "type": "registry",
    },
  },
  "proxy": "",
  "terminal": {
    "scrollbar": {
      "show": "auto"
    },
    "shell": "system",
    "font_family": "CaskaydiaCove Nerd Font",
    "toolbar": {
      "breadcrumbs": true,
    },
  },
  "git_panel": {
    "tree_view": true,
    "default_width": 240.0,
    "dock": "right",
  },
  "project_panel": {
    "hide_root": false,
    "default_width": 240.0,
    "entry_spacing": "standard",
    "hide_gitignore": false,
    "dock": "right",
  },
  "bottom_dock_layout": "left_aligned",
  "tabs": {
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_status_icon": true,
    "button_layout": "platform_default",
  },
  "search": {
    "case_sensitive": false,
  },
  "semantic_tokens": "combined",
  "which_key": {
    "enabled": true,
  },
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "session": {
    "trust_all_worktrees": true,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "agent": {
    "auto_compact": {
      "threshold": "70%"
    },
    "show_turn_stats": false,
    "thinking_display": "always_collapsed",
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "model_parameters": [],
  },
  "auto_indent_on_paste": true,
  "auto_install_extensions": {
    "one-dark-pro": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "minimap": {
    "show": "auto",
  },
  "preferred_line_length": 80,
  "soft_wrap": "bounded",
  "use_on_type_format": true,
  "wrap_guides": [80],
  "lsp": {
    "gopls": {
      "initialization_options": {
        "directoryFilters": ["-vendor"],
      },
    },
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
    },
  },
}
